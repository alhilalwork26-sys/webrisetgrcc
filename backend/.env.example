# Copy file ini menjadi backend/.env lalu isi nilainya.
# Jangan commit backend/.env atau file service account JSON.

# Path lokal ke service account JSON dari Google Cloud.
GOOGLE_SERVICE_ACCOUNT_FILE=/absolute/path/to/grcc-drive-service-account.json

# ID folder Google Drive tujuan.
# Contoh URL folder:
# https://drive.google.com/drive/folders/1AbCDefGhIjKlMn
# Maka ID-nya:
# GOOGLE_DRIVE_FOLDER_ID=1AbCDefGhIjKlMn
GOOGLE_DRIVE_FOLDER_ID=

# Opsional. Hanya dipakai untuk Google Workspace dengan domain-wide delegation.
# GOOGLE_WORKSPACE_DELEGATED_USER=nama@domainanda.com
